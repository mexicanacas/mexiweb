---
/**
 * Concert list component
 * Displays upcoming or previous concerts with consistent styling
 */
import { SkewButton } from './ui';

interface Concert {
	date: Date;
	venue: string;
	location: string;
	link?: string;
	pinned?: boolean;
}

interface Props {
	concerts: Concert[];
	type: 'upcoming' | 'previous';
}

const { concerts: rawConcerts, type } = Astro.props;

// Pinned concerts always appear first
const concerts = [...rawConcerts].sort((a, b) => (b.pinned ? 1 : 0) - (a.pinned ? 1 : 0));

const formatDate = (date: Date) =>
	date.toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' });

const shadowColors = ['#4bb655', '#d62828', '#fafafa'];
const getShadow = (index: number) =>
	`shadow-[6px_6px_0px_0px_${shadowColors[index % shadowColors.length]}]`;

const isUpcoming = type === 'upcoming';

const previousBorderColors = ['border-mexi-green/30', 'border-mexi-red/30', 'border-mexi-white/30'];

function getArticleClasses(concert: Concert, index: number) {
	const base = 'border-4 transition-all duration-300 hover:scale-[1.02] hover:rotate-0';

	if (concert.pinned && isUpcoming) {
		return `${base} bg-mexi-black border-mexi-white ${getShadow(index)} rotate-0 px-10 py-12 md:px-14 md:py-16`;
	}

	const rotation = index % 2 === 0 ? 'rotate-1' : '-rotate-1';

	if (isUpcoming) {
		return `${base} p-6 bg-mexi-black border-mexi-white ${getShadow(index)} ${rotation}`;
	}

	return `${base} p-6 bg-mexi-black/60 ${previousBorderColors[index % 3]} ${rotation}`;
}

function getHeadingClasses(concert: Concert) {
	if (concert.pinned && isUpcoming) return 'text-mexi-white text-3xl md:text-4xl';
	if (isUpcoming) return 'text-mexi-white text-xl md:text-2xl';
	return 'text-mexi-white/70 text-xl md:text-2xl';
}

function getDateClasses(concert: Concert) {
	if (concert.pinned && isUpcoming) return 'text-mexi-white/80 mt-1 text-base md:text-lg';
	if (isUpcoming) return 'text-sm md:text-base text-mexi-white/70';
	return 'text-sm md:text-base text-mexi-white/50';
}
---

<div class="flex flex-col gap-6 md:gap-8">
	{
		concerts.length === 0 ? (
			<p class="text-mexi-white/50 py-8 text-center italic">
				{isUpcoming
					? 'Ingen kommende konserter for øyeblikket.'
					: 'Ingen tidligere konserter å vise.'}
			</p>
		) : (
			concerts.map((concert, index) => (
				<>
					{concert.pinned && isUpcoming && index === 0 && <div class="mb-4 md:mb-6" />}
					<article class={getArticleClasses(concert, index)}>
						<div
							class:list={[
								'flex flex-col gap-4 md:flex-row md:items-center md:justify-between',
								concert.pinned && isUpcoming && 'text-center md:text-left'
							]}
						>
							<div class="flex-1">
								<h3 class:list={['mb-2 font-bold uppercase', getHeadingClasses(concert)]}>
									{concert.venue}
								</h3>
								<p class={getDateClasses(concert)}>
									{formatDate(concert.date)} · {concert.location}
								</p>
							</div>
							{concert.link && isUpcoming && (
								<SkewButton href={concert.link} target="_blank" size={concert.pinned ? 'lg' : 'md'}>
									Kjøp billetter
								</SkewButton>
							)}
						</div>
					</article>
					{concert.pinned && isUpcoming && <div class="mb-4 md:mb-6" />}
				</>
			))
		)
	}
</div>
