---
/**
 * Concerts page
 * Upcoming and previous concert listings
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundImage from '../components/BackgroundImage.astro';
import ConcertList from '../components/ConcertList.astro';
import { SkewBanner, SectionHeader } from '../components/ui';
import concertsImage from '../assets/images/background/concerts-image.jpg';

const allConcerts = [
	{
		date: new Date('2026-08-22'),
		venue: 'Fæsterålen Musikkfestival',
		location: 'Sortland',
		link: 'https://www.festeralen.no/artister-2026/los-mexicanacas'
	},
	{
		date: new Date('2026-08-15'),
		venue: 'Hovden Fjellfestival',
		location: 'Hovden',
		link: 'https://hovden.com/hovden-fjellfestival'
	},
	{
		date: new Date('2026-08-01'),
		venue: 'Hygga 2026',
		location: 'Sjusjøen',
		link: 'https://www.hyggafjellkro.no/konsert-hygga-2026'
	},
	{
		date: new Date('2026-07-11'),
		venue: 'GOD NOK Festivalen',
		location: 'Steigen',
		link: 'https://www.godnokfestivalen.no/los-mexicanacas/'
	},
	{
		date: new Date('2026-07-10'),
		venue: 'Slottsfjell',
		location: 'Tønsberg',
		link: 'https://slottsfjell.no/artister/los-mexicanacas/'
	},
	{
		date: new Date('2026-05-30'),
		venue: 'Rockefeller',
		location: 'Oslo',
		link: 'https://www.ticketmaster.no/event/los-mexicanacas-billetter/455694836',
		pinned: true
	},
	{
		date: new Date('2025-07-11'),
		venue: 'Slottsfjell',
		location: 'Tønsberg'
	},
	{
		date: new Date('2025-02-08'),
		venue: 'Vulkan Arena',
		location: 'Oslo'
	},
	{
		date: new Date('2024-05-04'),
		venue: 'SALT art & music',
		location: 'Oslo'
	},
	{
		date: new Date('2023-11-17'),
		venue: 'John Dee',
		location: 'Oslo'
	},
	{
		date: new Date('2022-06-11'),
		venue: 'Lufthavna MIR',
		location: 'Oslo'
	},
	{
		date: new Date('2021-03-19'),
		venue: 'Storsalen – Studentersamfundet i Trondhjem',
		location: 'Trondheim'
	},
	{
		date: new Date('2018-03-23'),
		venue: 'Bursdagen til faren til en kompis',
		location: 'Trondheim'
	}
];

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcomingConcerts = allConcerts
	.filter((c) => c.date >= today)
	.sort((a, b) => a.date.getTime() - b.date.getTime());

const previousConcerts = allConcerts
	.filter((c) => c.date < today)
	.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout
	title="Konserter | Los Mexicanacas"
	description="Se våre kommende konserter, festivaler og hvor Los Mexicanacas har spilt tidligere. Kjøp billetter til våre forestående show!"
>
	<BackgroundImage alt="Bilde fra konserten på Vulkan arena" src={concertsImage} />
	<div class="text-mexi-white mx-auto w-full max-w-4xl px-4 py-12 md:px-12">
		<!-- Header banner -->
		<SkewBanner class="mb-8 text-center md:mb-12">
			<h1 class="text-3xl md:text-5xl">SE OSS LIVE!</h1>
		</SkewBanner>

		<!-- Upcoming Concerts Section -->
		<section class="mb-12 md:mb-16">
			<SectionHeader title="Kommende Konserter" subtitle="Bli med på en uforglemmelig kveld!" />
			<ConcertList concerts={upcomingConcerts} type="upcoming" />
		</section>

		<!-- Previous Concerts Section -->
		<section>
			<SectionHeader title="Tidligere Konserter" subtitle="Se hvor vi har spredt fiesta." />
			<ConcertList concerts={previousConcerts} type="previous" />
		</section>
	</div>
</BaseLayout>
